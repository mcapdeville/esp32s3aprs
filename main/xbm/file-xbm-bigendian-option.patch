Description: Add bigendian support for XBM files
  This patch add an option to the save dialog of XBM file plugin for
big endian support. This option reverse bits order of encoded word (8 or
 16 bits). This is for compatibility with somme LCD/EPD display that
encode the top left pixel in the MSB (big endian)

Author:  <m.capdeville@no-lgo.org>
Last-Update: 2026-02-13

--- gimp-2.10.34.orig/plug-ins/common/file-xbm.c
+++ gimp-2.10.34/plug-ins/common/file-xbm.c
@@ -77,6 +77,7 @@ typedef struct _XBMSaveVals
   gchar    prefix[MAX_PREFIX + 1];
   gboolean write_mask;
   gchar    mask_ext[MAX_MASK_EXT + 1];
+  gint     bigendian;
 } XBMSaveVals;
 
 static XBMSaveVals xsvals =
@@ -88,7 +89,8 @@ static XBMSaveVals xsvals =
   0,                    /* y_hot */
   DEFAULT_PREFIX,       /* prefix */
   FALSE,                /* write_mask */
-  "-mask"
+  "-mask",
+  FALSE
 };
 
 
@@ -1155,6 +1157,16 @@ save_image (GFile        *file,
                         goto fail;
                     }
 
+                  if  (xsvals.bigendian)
+                  {
+                      // Reverse bit order
+                      if (intbits == 16)
+                          c = ((c&0xFF00)>>8) | ((c&0x00ff)<<8);
+                      c = ((c&0xF0f0)>>4) | ((c&0x0F0f)<<4);
+                      c = ((c&0xcccc)>>2) | ((c&0x3333)<<2);
+                      c = ((c&0xaaaa)>>1) | ((c&0x5555)<<1);
+                  }
+
                   if (! print (output, error, intfmt, c))
                     goto fail;
 
@@ -1175,7 +1187,7 @@ save_image (GFile        *file,
                   else
                     c |= ((data[rowoffset + k] == dark) ? 1 : 0) << (thisbit ++);
                 }
-            }
+          }
 
           if (thisbit != 0)
             {
@@ -1197,7 +1209,17 @@ save_image (GFile        *file,
                     goto fail;
                 }
 
-              if (! print (output, error, intfmt, c))
+              if  (xsvals.bigendian)
+              {
+                  // Reverse bit order
+                  if (intbits == 16)
+                      c = ((c&0xFF00)>>8) | ((c&0x00ff)<<8);
+                  c = ((c&0xF0f0)>>4) | ((c&0x0F0f)<<4);
+                  c = ((c&0xcccc)>>2) | ((c&0x3333)<<2);
+                  c = ((c&0xaaaa)>>1) | ((c&0x5555)<<1);
+              }
+
+			  if (! print (output, error, intfmt, c))
                 goto fail;
             }
         }
@@ -1269,6 +1291,16 @@ save_dialog (gint32 drawable_ID)
                     G_CALLBACK (gimp_toggle_button_update),
                     &xsvals.x10_format);
 
+  /* Reverse bits order */
+  toggle = gtk_check_button_new_with_mnemonic (_("Big endian bits order"));
+  gtk_box_pack_start (GTK_BOX (vbox), toggle, FALSE, FALSE, 0);
+  gtk_toggle_button_set_active (GTK_TOGGLE_BUTTON (toggle), xsvals.bigendian);
+  gtk_widget_show (toggle);
+
+  g_signal_connect (toggle, "toggled",
+          G_CALLBACK (gimp_toggle_button_update),
+          &xsvals.bigendian);
+
   table = gtk_table_new (2, 2, FALSE);
   gtk_table_set_col_spacings (GTK_TABLE (table), 6);
   gtk_table_set_row_spacings (GTK_TABLE (table), 6);
